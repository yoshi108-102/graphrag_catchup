      <data key="d1">"Christmas Past is an event highlighted by the Ghost's presence, focusing on Scrooge's reflections on his formative years and key turning points in his life."</data>
      <data key="d2">chunk-b2f98bc7abb0c67d4c86055c7fd72218</data>
    </node>
    <node id="&quot;THE APPRENTICES&quot;">
