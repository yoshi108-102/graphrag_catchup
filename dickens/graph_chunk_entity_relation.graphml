    <node id="&quot;PETER&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Peter is a member of the Cratchit family who shows camaraderie with Bob."</data>
      <data key="d2">chunk-91572b3cd42786ba4cb2f180ca25cbf4</data>
    </node>
    <node id="&quot;THE GHOST OF CHRISTMAS YET TO COME&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Ghost of Christmas Yet to Come is a phantom that shows Scrooge potential future outcomes, highlighting his fears and hopes."&lt;SEP&gt;"The Ghost of Christmas Yet to Come is a solemn, spectral figure that guides Scrooge through visions of potential future events, highlighting Scrooge's fears and stirring his resolve to change."</data>
      <data key="d2">chunk-91572b3cd42786ba4cb2f180ca25cbf4</data>
    </node>
