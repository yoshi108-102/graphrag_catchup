      <data key="d2">chunk-e1f29eeadc1d8ab46dc8a0bbd3c56b64</data>
    </node>
    <node id="&quot;DECEASED MAN&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Deceased Man is referenced throughout the text, as his possessions are being plundered and discussed by others."</data>
