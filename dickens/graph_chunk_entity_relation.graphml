      <data key="d2">chunk-8bc1edd983869352d14cf0886a9175a7</data>
    </node>
    <node id="&quot;THE COOK&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Cook is a worker at the party, arriving with her brother's particular friend, the milkman."</data>
      <data key="d2">chunk-8bc1edd983869352d14cf0886a9175a7</data>
    </node>
    <node id="&quot;THE BOY FROM OVER THE WAY&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Boy from Over the Way is a guest at the party, trying to stay inconspicuous due to not having enough to eat from his master."</data>
      <data key="d2">chunk-8bc1edd983869352d14cf0886a9175a7</data>
    </node>
    <node id="&quot;THE GIRL FROM NEXT DOOR BUT ONE&quot;">
