      <data key="d3">9.0</data>
      <data key="d4">"The Ghost of Christmas Present transforms Scrooge's Room into a festive and abundant space, symbolizing the spirit of Christmas."</data>
      <data key="d5">chunk-843b5b2f944c7413d9ca876e2e2f151f</data>
      <data key="d6">1</data>
    </edge>
